# Copy this file to .env and adjust values before starting the container.
# cp .env.example .env

# Password for the VNC session (shown when connecting via noVNC)
VNC_PASSWORD=changeme

# Desktop resolution (width x height)
VNC_GEOMETRY=1920x1080

# Host port noVNC is exposed on (access at http://localhost:<port>/vnc.html)
NOVNC_PORT=6080
